# ============================================
# Kuurier Server - Production Environment
# Copy to .env.production and fill in values
# ============================================

# Database
DB_USER=kuurier
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=kuurier

# Security (REQUIRED - generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_GENERATE_32_CHAR_SECRET_KEY
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARACTERS!

# Redis (generate with: openssl rand -hex 32)
REDIS_PASSWORD=CHANGE_ME_GENERATE_HEX_PASSWORD

# CORS (your app domains, comma-separated)
CORS_ALLOWED_ORIGINS=https://app.kuurier.com,https://kuurier.com,https://app.kuurier.org,https://kuurier.org

# APNs Push Notifications (optional)
# APNS_KEY_PATH=/app/certs/AuthKey.p8
# APNS_KEY_ID=YOUR_KEY_ID
# APNS_TEAM_ID=YOUR_TEAM_ID
# APNS_BUNDLE_ID=com.kuurier.app
# APNS_PRODUCTION=true

# Blue-Green Versions (managed by deploy.sh)
BLUE_VERSION=latest
GREEN_VERSION=latest
